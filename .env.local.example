# ─── Mindscape Environment Variables ───────────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# .env.local is listed in .gitignore — it is NEVER committed to version control.
#
# HOW TO GET A YOUTUBE API KEY:
#   1. Go to https://console.cloud.google.com/
#   2. Create a new project (or select an existing one)
#   3. Go to "APIs & Services" → "Enable APIs and Services"
#   4. Search for "YouTube Data API v3" and enable it
#   5. Go to "APIs & Services" → "Credentials" → "Create Credentials" → "API Key"
#   6. Copy the key and paste it below
#   7. (Recommended) Restrict the key to "YouTube Data API v3" only
#
# The key is only ever read server-side (in app/api/meditations/route.ts).
# It is never exposed to the browser.

YOUTUBE_API_KEY=your_api_key_here
