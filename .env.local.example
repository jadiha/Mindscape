# ─── Mindscape Environment Variables ───────────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# .env.local is listed in .gitignore — it is NEVER committed to version control.

# ── YouTube Data API v3 ────────────────────────────────────────────────────────
# Required for meditation video recommendations.
# Get one free at: console.cloud.google.com → APIs & Services → YouTube Data API v3 → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Google OAuth (Calendar integration) ───────────────────────────────────────
# Required for "Connect Google Calendar" feature.
#
# Setup steps:
#   1. Go to console.cloud.google.com
#   2. Create or select a project
#   3. Enable: Google Calendar API
#   4. Go to APIs & Services → Credentials → Create → OAuth 2.0 Client ID
#   5. Application type: Web application
#   6. Authorized redirect URI: http://localhost:3000/api/auth/callback/google
#   7. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── NextAuth ───────────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET: any random string (used to sign session cookies)
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000
